# Firebase service account JSON file path or raw JSON string
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Or use FIREBASE_SERVICE_ACCOUNT_KEY with a JSON string
# FIREBASE_SERVICE_ACCOUNT_KEY={...}

# Firebase Realtime Database or Firestore URL
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Firebase Auth API key for client-side sign-in
FIREBASE_API_KEY=your_firebase_api_key
